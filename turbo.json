{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NODE_ENV",
    "NEO4J_URI",
    "NEO4J_USER",
    "NEO4J_PASSWORD",
    "DATABASE_URL",
    "REDIS_URL",
    "LLM_API_KEY",
    "LLM_BASE_URL",
    "LLM_MODEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "tsconfig.json"]
    },
    "clean": {
      "cache": false
    }
  }
}
