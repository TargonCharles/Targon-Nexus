{
  "name": "@arp/ui",
  "version": "0.1.0",
  "description": "Shared UI components for the Targon Nexus (Targon Nexus) — AI-native academic knowledge graph platform for the ARPES research community",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./SearchBar": "./dist/components/SearchBar.js",
    "./GraphCanvas": "./dist/components/GraphCanvas.js",
    "./EntityCard": "./dist/components/EntityCard.js",
    "./PersonProfile": "./dist/components/PersonProfile.js",
    "./LabProfile": "./dist/components/LabProfile.js",
    "./EquipmentCard": "./dist/components/EquipmentCard.js",
    "./Timeline": "./dist/components/Timeline.js",
    "./EvidenceBadge": "./dist/components/EvidenceBadge.js",
    "./ConfidenceIndicator": "./dist/components/ConfidenceIndicator.js",
    "./FilterPanel": "./dist/components/FilterPanel.js",
    "./EntitySearchResult": "./dist/components/EntitySearchResult.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "build": "tsc && vite build",
    "lint": "eslint src/ --ext .ts,.tsx --max-warnings 0",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@arp/types": "workspace:*",
    "@arp/shared": "workspace:*",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.1"
  },
  "keywords": [
    "arp",
    "arpes",
    "academic-knowledge-graph",
    "ui-components",
    "react",
    "research-community"
  ],
  "license": "MIT",
  "sideEffects": false
}
