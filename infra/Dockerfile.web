# =============================================================================
# ARP Web — Next.js Frontend Dockerfile (Multi-stage)
# =============================================================================
# Target: node:18-alpine production image
# Build context: repository root
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Dependencies
# ---------------------------------------------------------------------------
FROM node:22-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy workspace config and lockfile for monorepo support
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc* ./
COPY apps/web/package.json ./apps/web/
COPY packages/*/package.json ./packages/

# Install pnpm and dependencies
RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --frozen-lockfile --filter @arp/web

# ---------------------------------------------------------------------------
# Stage 2: Builder
# ---------------------------------------------------------------------------
FROM node:22-alpine AS builder
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy installed dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages ./packages

COPY . .

# Define build-time arguments for Next.js
ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ARG NEXT_PUBLIC_NEO4J_URI=bolt://localhost:7687
ARG NEXT_PUBLIC_APP_ENV=production
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_NEO4J_URI=${NEXT_PUBLIC_NEO4J_URI}
ENV NEXT_PUBLIC_APP_ENV=${NEXT_PUBLIC_APP_ENV}
ENV NEXT_TELEMETRY_DISABLED=1

# Build Next.js application with standalone output
RUN npx next build apps/web

# ---------------------------------------------------------------------------
# Stage 3: Production Runner
# ---------------------------------------------------------------------------
FROM node:22-alpine AS production
RUN apk add --no-cache tini curl
WORKDIR /app

# Create non-root user
RUN addgroup -g 1001 -S arp && adduser -S arp -u 1001 -G arp

# Copy standalone output from Next.js build
COPY --from=builder --chown=arp:arp /app/apps/web/.next/standalone ./
COPY --from=builder --chown=arp:arp /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=arp:arp /app/apps/web/public ./apps/web/public

# Copy next.config if needed at runtime
COPY --from=builder --chown=arp:arp /app/apps/web/next.config.* ./apps/web/

USER arp

ENV NODE_ENV=production
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD curl -f http://localhost:${PORT}/api/health || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "apps/web/server.js"]

# ---------------------------------------------------------------------------
# Stage 4: Development (targeted via docker compose)
# ---------------------------------------------------------------------------
FROM node:22-alpine AS development
RUN apk add --no-cache libc6-compat python3 make g++
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc* ./

RUN pnpm install --frozen-lockfile

COPY . .

# Use the built-in 'node' user for development (not root)
RUN chown -R node:node /app
USER node

EXPOSE 3000

CMD ["pnpm", "run", "--filter", "@arp/web", "dev"]
