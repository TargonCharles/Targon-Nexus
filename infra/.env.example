# =============================================================================
# Targon Nexus — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your environment.
#   cp infra/.env.example .env
# Never commit .env (or .env.local, .env.production) to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Neo4j — Knowledge Graph Database
# ---------------------------------------------------------------------------
# URI format: bolt://<host>:<port>  or  neo4j+s://<host>:<port>
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# Neo4j database name (default: neo4j)
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# PostgreSQL — Relational Database
# ---------------------------------------------------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://arp:changeme@localhost:5432/arp
# Or split into parts:
# POSTGRES_USER=arp
# POSTGRES_PASSWORD=changeme
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=arp

# ---------------------------------------------------------------------------
# Redis — Cache / Message Queue
# ---------------------------------------------------------------------------
# Format: redis://[<user>:<password>@]<host>:<port>[/<db>]
REDIS_URL=redis://:redispass@localhost:6379
# Or split:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=redispass

# ---------------------------------------------------------------------------
# LLM / AI Configuration
# ---------------------------------------------------------------------------
# The platform uses LLM for: entity extraction, paper summarization,
# research interest matching, and knowledge graph enrichment.
#
# Set LLM_PROVIDER to one of: openai | anthropic | azure | local
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# LLM_MODEL=gpt-4o-mini  # cheaper alternative for high-volume tasks
# LLM_MODEL=claude-3-5-sonnet-20241022  # if using Anthropic

# Optional: separate model for lightweight tasks (keyword extraction, etc.)
LLM_LIGHT_MODEL=gpt-4o-mini

# Maximum tokens per LLM request
LLM_MAX_TOKENS=4096
# Temperature for creative tasks (0.0 - 2.0)
LLM_TEMPERATURE=0.3
# Request timeout in milliseconds
LLM_TIMEOUT_MS=60000

# ---------------------------------------------------------------------------
# Crawler Service
# ---------------------------------------------------------------------------
# Maximum concurrent browser instances
CRAWLER_CONCURRENCY=3
# Run browsers in headful mode (false = headless)
CRAWLER_HEADFUL=false
# Maximum crawl depth per job
CRAWLER_MAX_DEPTH=3
# Delay between requests to same domain (milliseconds)
CRAWLER_POLITENESS_DELAY=1000
# Request timeout per page (milliseconds)
CRAWLER_REQUEST_TIMEOUT=30000
# Metrics port for health checks
CRAWLER_METRICS_PORT=9090
# Crawler storage directory (inside container)
CRAWLER_STORAGE_DIR=/app/data/datasets

# ---------------------------------------------------------------------------
# API Server (NestJS)
# ---------------------------------------------------------------------------
API_PORT=3001
NODE_ENV=development

# JWT authentication
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRATION=7d

# ---------------------------------------------------------------------------
# Web Frontend (Next.js)
# ---------------------------------------------------------------------------
WEB_PORT=3000
# Public-facing API URL (used in browser-side code)
NEXT_PUBLIC_API_URL=http://localhost:3001
# Public-facing Neo4j URI (used by browser-side graph visualization)
NEXT_PUBLIC_NEO4J_URI=bolt://localhost:7687
# Application title
NEXT_PUBLIC_APP_TITLE=Targon Nexus — Targon Nexus

# ---------------------------------------------------------------------------
# Nginx Reverse Proxy
# ---------------------------------------------------------------------------
NGINX_PORT=8080

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log levels: error | warn | info | debug | trace
LOG_LEVEL=debug
# Log format: json | pretty
LOG_FORMAT=pretty
# Enable SQL query logging in development
LOG_SQL_QUERIES=false

# ---------------------------------------------------------------------------
# Email (optional — for notifications, password reset)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM="Targon Nexus <noreply@example.com>"

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Enable AI-powered features
FEATURE_AI_ENRICHMENT=true
# Enable automatic paper crawling via scheduler
FEATURE_AUTO_CRAWL=true
# Enable GraphQL playground (disable in production)
FEATURE_GRAPHQL_PLAYGROUND=true
# Enable rate limiting
FEATURE_RATE_LIMIT=true

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
# Sentry DSN for error tracking
SENTRY_DSN=
# OpenTelemetry endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=
# Datadog API key
DD_API_KEY=
