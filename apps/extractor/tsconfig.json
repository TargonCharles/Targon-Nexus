{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@arp/shared": ["../../packages/shared/src"],
      "@arp/shared/*": ["../../packages/shared/src/*"],
      "@arp/types": ["../../packages/types/src"],
      "@arp/types/*": ["../../packages/types/src/*"],
      "@arp/prompts": ["../../packages/prompts/src"],
      "@arp/prompts/*": ["../../packages/prompts/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
